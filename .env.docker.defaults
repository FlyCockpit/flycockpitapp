# =============================================================================
# .env.docker.defaults
#
# Committed placeholder values loaded by docker-compose.agent.yml (the
# port-parameterized local stack for agent UI testing). These exist so a fresh
# clone can run `pnpm dev:docker <port>` with no manual env setup.
#
# ┌───────────────────────────────────────────────────────────────────────────┐
# │ READ THIS BEFORE DEPLOYING TO PRODUCTION                                  │
# │                                                                           │
# │ Nothing in this file is safe to reuse in production. These values only    │
# │ work locally because the stack:                                           │
# │   * is reachable only from localhost on the host that started it          │
# │   * stores DB + Redis state in the container's writable layer (wiped on   │
# │     `pnpm dev:docker:down`), so placeholder creds can't leak real data    │
# │   * is never loaded by the deploy pipeline (Dockerfile ignores this file) │
# │                                                                           │
# │ Replace every placeholder value before production use.                    │
# └───────────────────────────────────────────────────────────────────────────┘
#
# Layering: compose loads this file FIRST and .env SECOND, so anything you put
# in a gitignored `.env` at the repo root overrides these. Use `.env` for real
# external integrations (SMTP, SSO, VAPID keys, paid third-party APIs).
# =============================================================================

# --- Auth -------------------------------------------------------------------
# 64-char placeholder. The env validator flags it as weak on startup — that
# warning is intentional, it is the "you are in insecure local mode" signal.
# In production the same validator would THROW, which is what you want.
BETTER_AUTH_SECRET=docker_dev_placeholder_do_not_use_in_production_1234567890abcdef

# Signup stays open in dev so agents can exercise the sign-up flow.
SIGNUP_ENABLED=true

# --- CORS -------------------------------------------------------------------
# Leave CORS_ORIGIN unset. Same-origin (vite dev server proxies /api, /rpc,
# /ws to the in-container server on :3000) means CSRF plugin is off in dev.
# Production must set CORS_ORIGIN if the web and server are on different
# origins.

# --- SMTP (mailpit) ---------------------------------------------------------
# Point the mailer at the in-stack `mailpit` service (see docker-compose.agent
# .yml). This makes the REAL signup → email-verification → 2FA flow work
# offline with zero credentials: verification emails are captured by mailpit
# instead of hitting a real relay. Read them at the mailpit web UI / REST API
# (host port = web port + 5000; see `.agent-ports.json` → "mailpit"). No
# SMTP_USER/SMTP_PASS — mailpit accepts unauthenticated, unencrypted mail.
#
# To send for real instead (AgentMail, Postmark, SES, …), set SMTP_HOST/PORT/
# USER/PASS/FROM in .env (gitignored) — those override these defaults.
SMTP_HOST=mailpit
SMTP_PORT=1025
SMTP_FROM=noreply@dev.local

# --- SSO / VAPID / ADMIN_EMAILS --------------------------------------------
# Intentionally unset. The features gracefully degrade:
#   * no VAPID   → web push is disabled
#   * no SSO_*   → SSO login button is hidden
#   * empty      → no users have admin privileges (fine for UI testing)
#     ADMIN_EMAILS
#
# To enable any of these locally, put the real values in .env (gitignored).

# --- Rate limiting ----------------------------------------------------------
# Sensible defaults live in packages/env/src/server.ts. Override via .env only
# if you need to test rate-limit behavior.

# --- Translation provider --------------------------------------------------
# Intentionally unset. Put OPENROUTER_API_KEY (or ANTHROPIC_API_KEY +
# TRANSLATION_PROVIDER=anthropic) in your gitignored .env to exercise locale
# bundle translation locally.

# --- Relay ------------------------------------------------------------------
# Disposable local defaults for the relay service. The agent stack overrides
# RELAY_JWKS_URL to use the in-stack server URL.
RELAY_PORT=3010
