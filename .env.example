# =============================================================================
# This is the single canonical .env location — loaded by every package.
# Copy to .env and fill in real values: cp .env.example .env
# Do NOT create per-app .env files (e.g. apps/server/.env).
#
# Server vs worker: the env package is split. The BullMQ worker validates only
# the worker-safe (shared) surface — DATABASE_URL, REDIS_URL, NODE_ENV, the
# S3_* block, the VIDEO_* knobs, and the translation keys. The server-only
# vars (BETTER_AUTH_*, CORS_ORIGIN, SSO_*, SIGNUP_ENABLED, VAPID_*, SMTP_*,
# ADMIN_EMAILS, RATE_LIMIT_*, IMAGE_*, ASSET_UPLOAD_MAX_BYTES)
# are NOT required by a worker-only deployment. For local dev you set
# everything in one file regardless; the split only matters when you split the
# server and worker across separate hosts. Each section below is tagged
# [shared] or [server-only] accordingly.
# =============================================================================

# Database — [shared] (server + worker)
DATABASE_URL=postgresql://postgres:password@localhost:5432/flycockpit

# Server listen port — [server-only]. Defaults to 3000. Leave unset for the
# default portless dev flow; portless injects PORT per app. Use SERVER_PORT only
# for raw local runs (`pnpm dev:raw`) or container overrides.
# SERVER_PORT=3000

# Auth — [server-only] (BETTER_AUTH_* not validated/required by the worker)
# BETTER_AUTH_SECRET is REQUIRED and must be at least 32 characters.
# It is auto-generated when you run `pnpm setup`, or you can generate one
# manually with `pnpm generate:secret` and paste the value below.
# If this value is empty or too short, the app will refuse to start.
BETTER_AUTH_SECRET=
# Public app origin used by auth callbacks. Do not include a path, query string,
# hash, or credentials.
BETTER_AUTH_URL=https://flycockpit.localhost

# [server-only] Optional – set when a browser app runs on a different origin
# than the API (raw web dev, Expo web, split-origin deploys). Set only when the
# browser calls a separate API origin directly. Leave unset for the default
# portless/Vite proxy flow. Do not include a path, query string, or hash.
# CORS_ORIGIN=https://flycockpit.localhost

# [server-only] Optional – SSO / enterprise login
# SSO_ENABLED=true
# SSO_CLIENT_ID=
# SSO_CLIENT_SECRET=
# SSO_ISSUER=https://your-org.okta.com
# SSO_PROVIDER_NAME=Okta
# FORCE_SSO=false

# [server-only] Signup — DISABLED by default. New account creation is rejected and the
# signup form is hidden in the UI. This is the safe default for internal
# tools.
# To allow public signup (e.g. for a customer-facing app), set this to "true".
# Flipping this on requires SMTP to be configured below — email verification
# is enforced on signup and the server will refuse to boot in production
# without it.
# SIGNUP_ENABLED=true

# Redis — [shared] (server + worker)
REDIS_URL=redis://localhost:6379

# [server-only] Optional relay URL returned to CLI/browser clients when minting
# relay connector/client tokens. Defaults to BETTER_AUTH_URL with /ws, which is
# correct only when your proxy routes /ws to the relay. Set this to the public
# relay WebSocket base in split-service deployments, e.g. wss://relay.example.com/ws.
# COCKPIT_RELAY_URL=wss://relay.example.com/ws

# [server-only] Web Push — OPTIONAL. Only needed if you want to send push notifications.
# The app runs fine without these set. Generate keys with `pnpm generate:vapid`
# if/when you want to enable push.
# VAPID_PUBLIC_KEY=
# VAPID_PRIVATE_KEY=
# VAPID_SUBJECT=mailto:admin@example.com

# [server-only] Email (SMTP) — REQUIRED if SIGNUP_ENABLED=true (email verification is
# enforced on signup). The server will refuse to boot in production if signup
# is enabled without SMTP. Otherwise optional — leave commented out if you
# don't have any email flows wired up yet.
# Local dev: docker run -d -p 1025:1025 -p 8025:8025 axllent/mailpit
#   then set SMTP_HOST=localhost, SMTP_PORT=1025 and open http://localhost:8025
# SMTP_HOST=localhost
# SMTP_PORT=1025
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# [server-only] Admin — comma-separated list of emails granted admin privileges.
# Emails are trimmed and lowercased at parse time.
# ADMIN_EMAILS=admin@example.com,other@example.com

# NOTE: There is no auth-bypass mode. To test the real signup →
# email-verification → 2FA flow locally, use the disposable docker stack
# (`pnpm dev:docker`) — it ships an in-stack mailpit SMTP sink that captures
# verification email offline with zero credentials.

# [server-only] Rate limiting (optional tuning — sensible defaults are built in)
# RATE_LIMIT_RPC_POINTS=100
# RATE_LIMIT_RPC_DURATION=60
# RATE_LIMIT_AUTH_POINTS=10
# RATE_LIMIT_AUTH_DURATION=60
# RATE_LIMIT_AUTH_BLOCK_DURATION=900
# RATE_LIMIT_SIGNUP_POINTS=3
# RATE_LIMIT_SIGNUP_DURATION=3600
# RATE_LIMIT_SIGNUP_BLOCK_DURATION=3600
#
# Reverse-proxy hops in front of the app, for deriving the real client IP used
# as the anonymous rate-limit key. Leave UNSET — the default auto-detects the
# client behind a private-network proxy (Render, Railway, Dokploy/nginx, Azure)
# and keys on the socket peer on bare/local deployments. Set it ONLY when a
# proxy in front of the app has a PUBLIC IP (e.g. Cloudflare): the exact number
# of proxies between the client and the app. 0 disables X-Forwarded-For.
# TRUST_PROXY_HOPS=1

# [shared] Translation provider — used by the locale translation scripts to fill
# UI/email JSON bundles. The app boots fine without these set.
#
# Default provider is `openrouter` with `anthropic/claude-haiku-4-5`. Cost
# at template-typical scale is roughly $0.05 for a full UI bundle (~552
# keys) and ~$0.005-0.01 per CMS Post translation per target locale.
#
# To swap to the Anthropic SDK directly: set TRANSLATION_PROVIDER=anthropic
# and provide ANTHROPIC_API_KEY. To swap models on OpenRouter: keep
# TRANSLATION_PROVIDER=openrouter and set TRANSLATION_MODEL to any
# OpenRouter model slug (e.g. `google/gemini-2.5-flash`).
#
# Full reference, including the provider abstraction (`packages/i18n-translate`),
# the auto-translate flow, and how to add a new locale:
#
# TRANSLATION_PROVIDER=openrouter
# Per-call model override. Defaults to `anthropic/claude-haiku-4-5` (OpenRouter)
# or `claude-haiku-4-5` (Anthropic direct) when unset.
# TRANSLATION_MODEL=anthropic/claude-haiku-4-5
# Required when TRANSLATION_PROVIDER=openrouter (the default).
# OPENROUTER_API_KEY=
# Required when TRANSLATION_PROVIDER=anthropic.
# ANTHROPIC_API_KEY=

# [shared] Asset storage (S3_*) — OPTIONAL. Required only if you enable
# uploads, CMS assets, avatars, or video storage. With S3_BUCKET unset,
# /api/assets/* and /api/images/* return 503 while the rest of the app boots.
# Works with AWS S3 and S3-compatible providers such as Cloudflare R2, MinIO,
# Backblaze B2, and DigitalOcean Spaces.
# S3_BUCKET=
# S3_REGION=auto
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_ENDPOINT=
# S3_FORCE_PATH_STYLE=false

# [server-only] Image proxy SSRF guard. Empty means external URL proxying is disabled; only
# stored assets can be transformed. Set to a comma-separated hostname allowlist
# when you intentionally proxy remote images.
# IMAGE_PROXY_ALLOWED_HOSTS=cdn.example.com,images.partner.com
# IMAGE_PROXY_TIMEOUT_MS=5000
# IMAGE_PROXY_MAX_BYTES=10485760
# IMAGE_TRANSFORM_MAX_INPUT_PIXELS=50000000

# [server-only] Hard cap on a single asset upload, in bytes. The server also enforces its
# own request body limits.
# ASSET_UPLOAD_MAX_BYTES=10485760

# [shared] Video transcoding — OPTIONAL. Requires S3-compatible storage, the worker, and
# ffmpeg/ffprobe available to the worker process. Keep ffmpeg/ffprobe available to the worker process.
# VIDEO_FFMPEG_PATH=ffmpeg
# VIDEO_FFPROBE_PATH=ffprobe
# VIDEO_ENABLE_4K=false
# VIDEO_UPLOAD_MAX_BYTES=10737418240
# VIDEO_TRANSCODE_CONCURRENCY=1
# VIDEO_AUDIO_TRANSCODE_CONCURRENCY=2
# VIDEO_TRANSCODE_MAX_DURATION_SECONDS=14400
# VIDEO_FFMPEG_THREADS=2
# VIDEO_FFMPEG_TIMELIMIT_SECONDS=21600
# VIDEO_X264_CRF=23
# VIDEO_X264_PRESET=slow

# Relay service — [relay-only]. The relay verifies public JWKS from the control
# plane and stores presence in Redis when REDIS_URL is set; without REDIS_URL it
# uses in-memory presence and is single-node only. RELAY_TOKEN_ISSUER defaults
# to BETTER_AUTH_URL. RELAY_JWKS_URL defaults to <issuer>/api/relay/jwks.json.
# RELAY_PORT=3010
# RELAY_TOKEN_ISSUER=https://flycockpit.localhost
# RELAY_JWKS_URL=https://flycockpit.localhost/api/relay/jwks.json
# RELAY_ID=relay-local-1
# RELAY_HEARTBEAT_MS=10000
# RELAY_LEASE_TTL_MS=30000
# RELAY_MAX_FRAME_BYTES=8388608
# RELAY_MAX_CHANNELS_PER_CLIENT=16
# RELAY_MAX_CONNECTIONS_PER_INSTANCE=1
# RELAY_CLIENT_RATE_LIMIT_PER_SECOND=60
# RELAY_CONTROL_INGEST_URL=
