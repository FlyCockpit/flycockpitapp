# Required - API server origin used by the Expo app. Do not include a path,
# query string, or hash.
#
# iOS simulator with raw local dev:
# EXPO_PUBLIC_SERVER_URL=http://localhost:3000
#
# Android emulator with raw local dev:
# EXPO_PUBLIC_SERVER_URL=http://10.0.2.2:3000
#
# Physical devices need an origin reachable from the device, usually your machine's
# LAN IP or a tunnel.
EXPO_PUBLIC_SERVER_URL=http://localhost:3000
