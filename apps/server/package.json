    "@orpc/zod": "catalog:",
    "@flycockpit/api": "workspace:*",
    "@flycockpit/auth": "workspace:*",
    "@flycockpit/db": "workspace:*",
    "@flycockpit/env": "workspace:*",
    "@flycockpit/queue": "workspace:*",
    "better-auth": "catalog:",
    "dotenv": "catalog:",
    "hono": "catalog:",
    "rate-limiter-flexible": "catalog:",
    "sharp": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@flycockpit/config": "workspace:*",
    "@types/node": "catalog:",
    "tsdown": "catalog:",
    "tsx": "catalog:",
