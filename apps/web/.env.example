# Optional – used in the app shell title/header. Defaults to "App"
# VITE_APP_NAME=My Business App

# Optional API origin – defaults to window.location.origin at runtime.
# Leave unset for the default portless/Vite proxy flow. Do not include a path,
# query string, or hash.
# VITE_SERVER_URL=http://localhost:3000

# Optional raw dev-server knobs. Leave unset with portless; it assigns ports
# and Vite proxies /api, /rpc, /mcp, /sw, /ws to https://api.flycockpit.localhost.
# Defaults without portless: Vite listens on 3001 and proxies to 3000. Do not
# include a path, query string, or hash.
# VITE_DEV_PORT=3001
# VITE_DEV_SERVER_URL=http://localhost:3000

# Optional – required for Web Push notifications
# VITE_VAPID_PUBLIC_KEY=
