{
  "name": "flycockpit",
  "license": "Apache-2.0 AND LicenseRef-FlyCockpit-Enterprise",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "dev": "portless",
    "dev:raw": "turbo dev",
    "build": "turbo build",
    "test": "turbo run test",
    "check-types": "turbo check-types",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "check:ci": "biome check .",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "dev:worker": "turbo -F worker dev",
    "dev:native": "pnpm doctor:native && turbo -F native dev",
    "native:android": "pnpm doctor:native && turbo -F native android",
    "native:ios": "pnpm doctor:native && turbo -F native ios",
    "native:web": "pnpm doctor:native && turbo -F native web",
    "db:push": "turbo -F @flycockpit/db db:push",
    "db:push:dangerous": "turbo -F @flycockpit/db db:push:dangerous",
    "db:seed": "turbo -F @flycockpit/db db:seed",
    "db:studio": "turbo -F @flycockpit/db db:studio",
    "db:generate": "turbo -F @flycockpit/db db:generate",
    "db:validate": "turbo -F @flycockpit/db db:validate",
    "dev:services": "bash scripts/compose.sh -f docker-compose.dev.yml up -d",
    "dev:services:stop": "bash scripts/compose.sh -f docker-compose.dev.yml down",
    "dev:docker": "bash scripts/dev-docker.sh",
    "dev:docker:logs": "bash scripts/dev-docker-logs.sh",
    "dev:docker:down": "bash scripts/dev-docker-down.sh",
    "find-free-port": "bash scripts/find-free-port.sh",
    "db:start": "turbo -F @flycockpit/db db:start",
    "db:watch": "turbo -F @flycockpit/db db:watch",
    "db:stop": "turbo -F @flycockpit/db db:stop",
    "db:down": "turbo -F @flycockpit/db db:down",
    "generate:secret": "node -e \"console.log(require('crypto').randomBytes(32).toString('hex'))\"",
    "generate:vapid": "pnpm -F @flycockpit/api exec web-push generate-vapid-keys",
    "setup": "tsx scripts/setup.ts",
    "doctor": "tsx scripts/doctor.ts",
    "doctor:native": "tsx scripts/native-doctor.ts",
    "doctor:react": "react-doctor . --offline -y",
    "doctor:react:diff": "react-doctor . --scope changed --base origin/main --offline -y",
    "knip": "knip",
    "knip:production": "knip --production",
    "theme:apply": "tsx scripts/theme-apply.ts",
    "i18n:translate": "tsx scripts/translate-locale-bundles.ts",
    "i18n:translate:mailer": "tsx scripts/translate-locale-bundles.ts --source-dir packages/mailer/src/locales/en-US --target-dir packages/mailer/src/locales/es-MX",
    "postinstall": "lefthook install",
    "dev:relay": "turbo -F relay dev"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "catalog:",
    "@flycockpit/env": "workspace:*",
    "@flycockpit/i18n-translate": "workspace:*",
    "dotenv": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@flycockpit/config": "workspace:*",
    "@types/node": "catalog:",
    "knip": "^6.17.1",
    "lefthook": "^2.1.9",
    "react-doctor": "^0.5.6",
    "tsx": "catalog:",
    "turbo": "^2.9.18",
    "typescript": "catalog:",
    "vitest": "catalog:"
  },
  "packageManager": "pnpm@11.1.2+sha512.415a1cc25974731e75455c1468371be74c5aa5fb7621b50d4056d222451609f11412f23fd602e6169f1e060466641f798597e1be961a10688836a67b16569499"
}
